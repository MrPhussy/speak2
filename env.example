# Copy to .env in this directory (speak2 root). Do not commit .env.

# Required for gated Hugging Face models (read-only token recommended).
HUGGING_FACE_HUB_TOKEN=hf_

# Optional: Unmute news feature
NEWSAPI_API_KEY=

# --- LLM: pick ONE deployment style ---
#
# (A) Local vLLM (single-GPU compose override): leave defaults in docker-compose.yml;
#     KYUTAI_LLM_URL=http://llm:8000 is set by upstream.
#
# (B) External OpenAI-compatible API on another host (split-LLM override):
#     Base URL WITHOUT /v1 — Unmute appends /v1 (unmute/llm/llm_utils.py).
#     KYUTAI_LLM_URL=http://YOUR_VLLM_HOST:8000
#     KYUTAI_LLM_MODEL=google/gemma-4-E2B-it
#     KYUTAI_LLM_API_KEY=EMPTY
#
# (C) Inception Mercury 2 (RunPod voice stack preset: compose/docker-compose.runpod.inception-mercury.yml):
#     https://www.inceptionlabs.ai/blog/introducing-mercury-2
#     https://docs.inceptionlabs.ai/get-started/get-started
KYUTAI_LLM_URL=https://api.inceptionlabs.ai
KYUTAI_LLM_MODEL=mercury-2
# Create at https://platform.inceptionlabs.ai/dashboard/api-keys — paste here for Unmute:
KYUTAI_LLM_API_KEY=
