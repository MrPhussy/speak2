# Copy to .env in this directory (speak2 root). Do not commit .env.

# Required for gated Hugging Face models (read-only token recommended).
HUGGING_FACE_HUB_TOKEN=hf_

# Optional: Unmute news feature
NEWSAPI_API_KEY=

# Backend → OpenAI-compatible LLM (vLLM, OpenRouter, etc.)
# Base URL without /v1 — the Unmute backend appends /v1 (see unmute/llm/llm_utils.py).
# Single-GPU compose: defaults to http://llm:8000 from upstream docker-compose.yml.
# Split-LLM compose: set to your RunPod vLLM URL, e.g. http://YOUR_POD_IP:8000
# KYUTAI_LLM_URL=http://llm:8000

# Explicit model id avoids autoselect failures when multiple models are registered.
KYUTAI_LLM_MODEL=google/gemma-4-E2B-it

# vLLM ignores this; OpenRouter/OpenAI need a real key.
KYUTAI_LLM_API_KEY=EMPTY
