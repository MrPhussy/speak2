# syntax=docker/dockerfile:1
# Single image: Traefik (file provider) + Next.js frontend + Unmute backend + Kyutai STT + Kyutai TTS.
# Intended for RunPod Pods (one container) and later Serverless once validated.
#
# Build (from speak2 repo root; submodule `unmute/` must be present):
#   docker build -f Dockerfile.runpod-allinone -t your-registry/speak2-unmute:runpod .
#
# Run (GPU required; pass secrets via env):
#   docker run --rm -it --gpus all -p 80:80 \
#     -e HUGGING_FACE_HUB_TOKEN=hf_... \
#     -e KYUTAI_LLM_API_KEY=... \
#     your-registry/speak2-unmute:runpod

ARG TARGETARCH
ARG TRAEFIK_TAG=v3.6.6

# -----------------------------------------------------------------------------
# Frontend (Next.js standalone)
# -----------------------------------------------------------------------------
FROM node:20-bookworm AS frontend-builder
WORKDIR /app
RUN corepack enable pnpm
COPY unmute/frontend/package.json unmute/frontend/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
COPY unmute/frontend/ ./
ENV NEXT_TELEMETRY_DISABLED=1
ENV NEXT_PUBLIC_IN_DOCKER=true
RUN pnpm run build

# -----------------------------------------------------------------------------
# Unmute backend (Python 3.12 + uv), same path as runtime (/opt/unmute)
# -----------------------------------------------------------------------------
FROM nvidia/cuda:12.8.1-devel-ubuntu22.04 AS backend-builder
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates libopus-dev pkg-config \
    && rm -rf /var/lib/apt/lists/*
COPY --from=ghcr.io/astral-sh/uv:0.6.17-debian /uv /usr/local/bin/uv
COPY --from=ghcr.io/astral-sh/uv:0.6.17-debian /uvx /usr/local/bin/uvx
ENV PATH="/usr/local/bin:${PATH}"
ENV UV_COMPILE_BYTECODE=1
WORKDIR /opt/unmute
RUN uv python install 3.12
COPY unmute/pyproject.toml unmute/uv.lock ./
RUN uv sync --no-dev --locked
COPY unmute/ ./
RUN uv sync --no-dev --locked

# -----------------------------------------------------------------------------
# Kyutai moshi-server (Rust + uv Python env for TTS)
# -----------------------------------------------------------------------------
FROM nvidia/cuda:12.8.1-devel-ubuntu22.04 AS moshi-builder
ENV DEBIAN_FRONTEND=noninteractive
ENV CXXFLAGS="-include cstdint"
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl build-essential ca-certificates libssl-dev libopus-dev git \
    pkg-config cmake wget dos2unix \
    && rm -rf /var/lib/apt/lists/*
RUN curl https://sh.rustup.rs -sSf | sh -s -- -y
ENV PATH=/root/.cargo/bin:${PATH}
COPY --from=ghcr.io/astral-sh/uv:0.7.2 /uv /usr/local/bin/uv
COPY --from=ghcr.io/astral-sh/uv:0.7.2 /uvx /usr/local/bin/uvx
ENV PATH="/usr/local/bin:${PATH}"
WORKDIR /opt/moshi
RUN wget -q https://raw.githubusercontent.com/kyutai-labs/moshi/4fae088e130f6b44d489aefc0ef1836745e921de/rust/moshi-server/pyproject.toml \
    && wget -q https://raw.githubusercontent.com/kyutai-labs/moshi/4fae088e130f6b44d489aefc0ef1836745e921de/rust/moshi-server/uv.lock
COPY unmute/services/moshi-server/configs ./configs
RUN uv python install 3.12 \
    && uv venv --python 3.12 .venv \
    && (uv sync --frozen || uv sync) \
    && CARGO_TARGET_DIR=/tmp/moshi-cargo-target cargo install --features cuda moshi-server@0.6.4 \
    && rm -rf /tmp/moshi-cargo-target \
    && install -m755 /root/.cargo/bin/moshi-server /opt/moshi/moshi-server

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
FROM nvidia/cuda:12.8.1-devel-ubuntu22.04 AS runtime
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl supervisor ffmpeg \
    libopus0 \
    && rm -rf /var/lib/apt/lists/*

# Traefik static binary (amd64 / arm64)
ARG TARGETARCH
ARG TRAEFIK_TAG
RUN set -eux; \
    case "$TARGETARCH" in \
      amd64) T_ARCH=amd64 ;; \
      arm64) T_ARCH=arm64 ;; \
      *) echo "unsupported TARGETARCH=$TARGETARCH" >&2; exit 1 ;; \
    esac; \
    curl -fsSL "https://github.com/traefik/traefik/releases/download/${TRAEFIK_TAG}/traefik_${TRAEFIK_TAG}_linux_${T_ARCH}.tar.gz" \
      | tar xz -C /usr/local/bin traefik

COPY --from=ghcr.io/astral-sh/uv:0.6.17-debian /uv /usr/local/bin/uv
COPY --from=ghcr.io/astral-sh/uv:0.6.17-debian /uvx /usr/local/bin/uvx
ENV PATH="/usr/local/bin:${PATH}"

COPY --from=backend-builder /opt/unmute /opt/unmute

COPY --from=frontend-builder /app/.next/standalone /opt/frontend
COPY --from=frontend-builder /app/.next/static /opt/frontend/.next/static
COPY --from=frontend-builder /app/public /opt/frontend/public

COPY --from=moshi-builder /opt/moshi /opt/moshi
RUN ln -sf /opt/moshi/moshi-server /usr/local/bin/moshi-server

RUN mkdir -p /etc/traefik /etc/supervisor /var/log/supervisor /opt/speak2
COPY runpod/traefik-static.yaml /etc/traefik/traefik-static.yaml
COPY runpod/traefik-dynamic.yaml /etc/traefik/dynamic.yaml
COPY runpod/supervisord.conf /etc/supervisor/supervisord.conf
COPY runpod/entrypoint.sh /opt/speak2/entrypoint.sh
COPY runpod/run-stt.sh /opt/speak2/run-stt.sh
COPY runpod/run-tts.sh /opt/speak2/run-tts.sh
COPY runpod/run-backend.sh /opt/speak2/run-backend.sh
COPY runpod/run-frontend.sh /opt/speak2/run-frontend.sh
RUN chmod +x /opt/speak2/*.sh /usr/local/bin/moshi-server

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=10s --start-period=300s --retries=3 \
    CMD curl -fsS http://127.0.0.1:80/ >/dev/null || exit 1

ENTRYPOINT ["/opt/speak2/entrypoint.sh"]
